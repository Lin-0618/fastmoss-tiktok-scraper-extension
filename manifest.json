{
  "manifest_version": 3,
  "name": "FastMoss TikTok 数据导出",
  "version": "0.1.0",
  "description": "抓取 FastMoss 视频页数据，自动翻页，并导出 TikTok 达人链接和完整表格 CSV。",
  "icons": {
    "128": "icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.fastmoss.com/*"
  ],
  "action": {
    "default_icon": {
      "128": "icon-128.png"
    },
    "default_title": "FastMoss 导出",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.fastmoss.com/*"
      ],
      "js": [
        "src/fastmoss-runtime.js",
        "src/fastmoss-utils.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
